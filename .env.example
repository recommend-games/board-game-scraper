# environment variables
LOG_LEVEL=DEBUG
LOG_SCRAPED_ITEMS=0
FEED_EXPORT_FILE_SUFFIX=<hostname>
# Scrape premium users
SCRAPE_PREMIUM_USERS_LIST=
SCRAPE_PREMIUM_USERS_CONFIG_DIR=
SCRAPE_PREMIUM_USERS_INTERVAL=1800
SCRAPE_PREMIUM_USERS_PREVENT_RESCRAPE_FOR=10800
# BGG username and password
BGG_USERNAME=
BGG_PASSWORD=
# Obtain your token from https://boardgamegeek.com/using_the_xml_api
BGG_API_AUTH_TOKEN=
# Optional CSV entrypoints for BGG spider (paths and column names)
BGG_GAMES_CSV_PATH=
BGG_USERS_CSV_PATH=
BGG_GAMES_ID_FIELD=bgg_id
BGG_USERS_NAME_FIELD=bgg_user_name
